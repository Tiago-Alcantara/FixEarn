// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum BillType {
  software
  utility
  other
}

// ── Models ─────────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  wallets        Wallet[]
  deposits       Deposit[]
  recurringBills RecurringBill[]
  yieldSnapshots YieldSnapshot[]

  @@map("companies")
}

model Wallet {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  address   String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id])
  deposits Deposit[]

  @@map("wallets")
}

model Deposit {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  walletId  String   @map("wallet_id")
  /// USDC amount in base units (7 decimal places)
  amount    BigInt
  txHash    String?  @map("tx_hash")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  wallet  Wallet  @relation(fields: [walletId], references: [id])

  @@map("deposits")
}

model RecurringBill {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  name        String
  billType    BillType @map("bill_type")
  /// USDC amount in base units (7 decimal places)
  amountDue   BigInt   @map("amount_due")
  dueDayOfMonth Int    @map("due_day_of_month")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("recurring_bills")
}

model YieldSnapshot {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  /// Yield balance in base units (7 decimal places)
  balance   BigInt
  apy       Decimal  @db.Decimal(10, 8)
  snapshotAt DateTime @default(now()) @map("snapshot_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("yield_snapshots")
}
