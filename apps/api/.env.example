DATABASE_URL=postgresql://yield2pay:yield2pay@localhost:5433/yield2pay?schema=public
PRIVY_APP_ID=privy_app_id
PRIVY_APP_SECRET=privy_app_secret
DEFINDEX_API_KEY=defindex_api_key
DEFINDEX_BASE_URL=https://api.defindex.io
VAULT_ADDRESS=C...vault_address
USDC_ADDRESS=C...usdc_address
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Stellar secret key (S...) of the account that sponsors fee bumps + funds new accounts
FEE_SPONSOR_SECRET_KEY=S...fee_sponsor_secret_key
PORT=3001
# CORS: comma-separated allowed web origins. Unset = reflect any origin (dev/MVP only).
# In production set to your deployed web domain, e.g. https://yield2pay.vercel.app
CORS_ORIGIN=http://localhost:3000
